# Database
DATABASE_URL="postgresql://user:password@localhost:5432/odheyati"

# App URL (Production Domain)
APP_URL="https://almotamed.com"
NEXT_PUBLIC_APP_URL="https://almotamed.com"

# Authentication
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"
ADMIN_EMAIL="admin@almotamed.com"
ADMIN_PASSWORD="change-this-password"

# Salla Webhook
SALLA_WEBHOOK_SECRET="your-salla-webhook-secret"

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET="odheyati-proofs"
CLOUDFLARE_R2_PUBLIC_BASE_URL="https://proofs.almotamed.com"

# AI Fallback (Gemini)
GEMINI_API_KEY=
AI_FALLBACK_ENABLED=false